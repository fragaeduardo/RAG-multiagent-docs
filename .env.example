# ==========================================
# 🔑 API KEYS (PREENCHA ESTES CAMPOS)
# ==========================================
OPENROUTER_API_KEY=sua_chave_do_openrouter_aqui
OPENAI_API_KEY=sua_chave_da_openai_aqui
GEMINI_API_KEY=sua_chave_do_gemini_aqui
HF_TOKEN=seu_token_do_huggingface_aqui

# ==========================================
# 🧠 MODELOS DA CAMADA GENERATIVA (RAG)
# ==========================================
LLM_PLANNER=openai/gpt-5.4-nano
LLM_RESUMIDOR_COMPACTADOR=qwen/qwen-2.5-72b-instruct
LLM_SINTETIZADOR_FINAL=openai/gpt-5.4-nano
LLM_JUDGE=anthropic/claude-sonnet-4.6

# ==========================================
# ⚙️ PARÂMETROS DE ORQUESTRAÇÃO (RAG)
# ==========================================
MAX_RETRIES=2
MAX_SUBQUERIES=8
RERANKER_TOP_K=15
RETRIEVAL_LIMIT=100
PREFETCH_LIMIT=300

# ==========================================
# ✂️ CONFIGURAÇÕES DE CHUNKING (ETL)
# ==========================================
ENABLE_MARKDOWN_SPLITTER=true
ENABLE_RECURSIVE_SPLITTER=true
ENABLE_SEMANTIC_CHUNKER=true
RECURSIVE_CHUNK_SIZE=3600
RECURSIVE_CHUNK_OVERLAP=400

# ==========================================
# 🚀 PERFORMANCE E HARDWARE (ETL)
# ==========================================
MAX_PARALLEL_WORKERS=2
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ==========================================
# 🤫 SILENCIAR LOGS DE DOWNLOAD
# ==========================================
HF_HUB_DISABLE_PROGRESS_BARS=1
